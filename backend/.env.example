# Stage 2 Aggregation — backend config
# Copy to .env to override defaults.

# Sentence-Transformers model used to embed grievance summaries.
MODEL_NAME=all-MiniLM-L6-v2

# DBSCAN cosine-distance threshold. Lower = stricter (fewer merges),
# higher = looser (more complaints grouped together). 0.0-1.0.
# 0.6 groups paraphrased/Hinglish complaints well with all-MiniLM-L6-v2.
DBSCAN_EPS=0.6

# Minimum samples for a DBSCAN core point. 1 => every grievance lands in a
# cluster (unique complaints become singleton Master Incidents).
DBSCAN_MIN_SAMPLES=1

# SQLite database file (relative to backend/ or absolute).
DB_PATH=aggregation.db

# Comma-separated allowed CORS origins for the frontend dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
